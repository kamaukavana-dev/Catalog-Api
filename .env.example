# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/catalog_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS / S3 Configuration (MinIO for local)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=catalog-media
S3_BASE_URL=http://localhost:9000/catalog-media

# Observability
TRACING_SAMPLE_RATE=1.0
OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
CATALOG_REQUIRE_API_KEY=false
CATALOG_API_KEYS=

# Application
ENVIRONMENT=local
LOG_LEVEL_CATALOG=DEBUG
